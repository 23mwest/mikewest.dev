---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Michael J West</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Intel+One+Mono:ital,wght@0,300..700;1,300..700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("theme");
        const mode =
          storedTheme === "light" ||
          storedTheme === "dark" ||
          storedTheme === "system"
            ? storedTheme
            : "system";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const isDark = mode === "system" ? prefersDark : mode === "dark";
        document.documentElement.dataset.theme = isDark ? "business" : "nord";
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
    <link rel="stylesheet" href="/styles.css" />
    <script type="module" src="/main.js"></script>
  </head>
  <body>
    <div class="drawer">
      <input id="my-drawer-2" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col">
        <!-- Navbar -->
        <div class="navbar bg-base-300 w-full relative">
          <div class="flex-none lg:hidden">
            <label
              for="my-drawer-2"
              aria-label="open sidebar"
              class="btn btn-square btn-ghost"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                class="inline-block h-6 w-6 stroke-current"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </label>
          </div>
          <div class="text-3xl font-bold mx-2 flex-1 px-2">Michael J West</div>
          <div
            class="ml-auto lg:ml-0 lg:absolute lg:left-1/2 lg:-translate-x-1/2"
          >
            <div class="tabs tabs-box">
              <input
                id="theme-tab-system"
                type="radio"
                name="theme_tabs"
                class="tab"
                aria-label="💻"
                value="system"
                checked
              />
              <input
                id="theme-tab-light"
                type="radio"
                name="theme_tabs"
                class="tab"
                aria-label="🌞"
                value="light"
              />
              <input
                id="theme-tab-dark"
                type="radio"
                name="theme_tabs"
                class="tab"
                aria-label="🌛"
                value="dark"
              />
            </div>
          </div>
          <div class="hidden flex-none lg:block">
            <ul class="menu menu-horizontal">
              <!-- Navbar menu content here -->
              <li><a href="/index.html" class="text-xl">Resume</a></li>
              <li><a href="/apps.html" class="text-xl">Apps</a></li>
            </ul>
          </div>
        </div>
        <!-- Page content -->
        <article>
          <slot />
        </article>
      </div>
      <div class="drawer-side">
        <label
          for="my-drawer-2"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <ul class="menu bg-base-300 min-h-full w-80 p-4">
          <!-- Sidebar content here -->
          <li><a class="text-xl" href="/index.html">Resume</a></li>
          <li><a class="text-xl" href="/apps.html">Apps</a></li>
        </ul>
      </div>
    </div>
  </body>
</html>
