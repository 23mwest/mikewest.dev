---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Michael J West</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Intel+One+Mono:ital,wght@0,300..700;1,300..700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("theme");
        const mode =
          storedTheme === "light" ||
          storedTheme === "dark" ||
          storedTheme === "system"
            ? storedTheme
            : "system";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const isDark = mode === "system" ? prefersDark : mode === "dark";
        document.documentElement.dataset.theme = isDark ? "business" : "nord";
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
    <style>
      .theme-tab-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
    </style>
    <link rel="stylesheet" href="/styles.css" />
    <script type="module" src="/main.js"></script>
  </head>
  <body>
    <div class="drawer">
      <input id="my-drawer-2" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col">
        <!-- Navbar -->
        <div class="navbar bg-base-300 w-full relative">
          <div class="flex-none lg:hidden">
            <label
              for="my-drawer-2"
              aria-label="open sidebar"
              class="btn btn-square btn-ghost"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                class="inline-block h-6 w-6 stroke-current"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </label>
          </div>
          <div class="text-3xl font-bold mx-2 flex-1 px-2">Michael J West</div>
          <div
            class="ml-auto lg:ml-0 lg:absolute lg:left-1/2 lg:-translate-x-1/2"
          >
            <div class="tabs tabs-box theme-tabs" role="tablist" aria-label="Theme selector">
              <input
                id="theme-tab-system"
                type="radio"
                name="theme_tabs"
                class="theme-tab-input"
                value="system"
                checked
              />
              <label
                for="theme-tab-system"
                class="tab theme-tab-label"
                data-theme-mode="system"
                aria-label="Use system theme"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <rect x="3" y="4" width="18" height="12" rx="2"></rect>
                  <path d="M8 20h8"></path>
                  <path d="M12 16v4"></path>
                </svg>
                <span class="sr-only">System</span>
              </label>
              <input
                id="theme-tab-light"
                type="radio"
                name="theme_tabs"
                class="theme-tab-input"
                value="light"
              />
              <label
                for="theme-tab-light"
                class="tab theme-tab-label"
                data-theme-mode="light"
                aria-label="Use light theme"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="4"></circle>
                  <path d="M12 2v2"></path>
                  <path d="M12 20v2"></path>
                  <path d="m4.93 4.93 1.41 1.41"></path>
                  <path d="m17.66 17.66 1.41 1.41"></path>
                  <path d="M2 12h2"></path>
                  <path d="M20 12h2"></path>
                  <path d="m6.34 17.66-1.41 1.41"></path>
                  <path d="m19.07 4.93-1.41 1.41"></path>
                </svg>
                <span class="sr-only">Light</span>
              </label>
              <input
                id="theme-tab-dark"
                type="radio"
                name="theme_tabs"
                class="theme-tab-input"
                value="dark"
              />
              <label
                for="theme-tab-dark"
                class="tab theme-tab-label"
                data-theme-mode="dark"
                aria-label="Use dark theme"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <path d="M12 3a7 7 0 1 0 9 9 9 9 0 1 1-9-9Z"></path>
                </svg>
                <span class="sr-only">Dark</span>
              </label>
            </div>
          </div>
          <div class="hidden flex-none lg:block">
            <ul class="menu menu-horizontal">
              <!-- Navbar menu content here -->
              <li><a href="/index.html" class="text-xl">Resume</a></li>
              <li><a href="/apps.html" class="text-xl">Apps</a></li>
              <li><a href="/links" class="text-xl">Links</a></li>
            </ul>
          </div>
        </div>
        <!-- Page content -->
        <article>
          <slot />
        </article>
      </div>
      <div class="drawer-side">
        <label
          for="my-drawer-2"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <ul class="menu bg-base-300 min-h-full w-80 p-4">
          <!-- Sidebar content here -->
          <li><a class="text-xl" href="/index.html">Resume</a></li>
          <li><a class="text-xl" href="/apps.html">Apps</a></li>
          <li><a class="text-xl" href="/links">Links</a></li>
        </ul>
      </div>
    </div>
  </body>
</html>
