---
import "../styles/global.css";

const normalizePath = (path) => {
  const withoutHashOrQuery = path.split("#")[0].split("?")[0];
  const withoutHtml =
    withoutHashOrQuery === "/index.html"
      ? "/"
      : withoutHashOrQuery.endsWith(".html")
        ? withoutHashOrQuery.slice(0, -5)
        : withoutHashOrQuery;
  const trimmed = withoutHtml.replace(/\/+$/, "");
  return trimmed || "/";
};

const currentPath = normalizePath(Astro.url.pathname);
const navItems = [
  { href: "/", label: "About", paths: ["/"] },
  { href: "/apps", label: "Apps", paths: ["/apps"] },
  { href: "/links", label: "Links", paths: ["/links"] },
  // {
  //   label: "Fun",
  //   children: [
  //     { href: "/snake", label: "Snake", paths: ["/snake"] },
  //     {
  //       href: "/theme-switcher",
  //       label: "Theme switcher",
  //       paths: ["/theme-switcher"],
  //     },
  //   ],
  // },
];

const isActivePath = (paths = []) =>
  paths.some((path) => normalizePath(path) === currentPath);

const isNavItemActive = (item) => {
  if (item.children) {
    return item.children.some((child) => isNavItemActive(child));
  }

  const paths = item.paths ?? (item.href ? [item.href] : []);
  return isActivePath(paths);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Michael J West</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Intel+One+Mono:ital,wght@0,300..700;1,300..700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const mode = localStorage.getItem("theme");
        const preferredMode =
          mode === "light" || mode === "dark" || mode === "system"
            ? mode
            : "system";
        const daisyThemes = [
          "light",
          "dark",
          "cupcake",
          "bumblebee",
          "emerald",
          "corporate",
          "synthwave",
          "retro",
          "cyberpunk",
          "valentine",
          "halloween",
          "garden",
          "forest",
          "aqua",
          "lofi",
          "pastel",
          "fantasy",
          "wireframe",
          "black",
          "luxury",
          "dracula",
          "cmyk",
          "autumn",
          "business",
          "acid",
          "lemonade",
          "night",
          "coffee",
          "winter",
          "dim",
          "nord",
          "sunset",
          "caramellatte",
          "abyss",
          "silk",
        ];
        const lightTheme = localStorage.getItem("themeLight");
        const darkTheme = localStorage.getItem("themeDark");
        const selectedLightTheme = daisyThemes.includes(lightTheme)
          ? lightTheme
          : "light";
        const selectedDarkTheme = daisyThemes.includes(darkTheme)
          ? darkTheme
          : "night";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const isDark =
          preferredMode === "system" ? prefersDark : preferredMode === "dark";
        document.documentElement.dataset.theme = isDark
          ? selectedDarkTheme
          : selectedLightTheme;
        document.documentElement.dataset.themeMode = preferredMode;
        document.documentElement.dataset.themeLight = selectedLightTheme;
        document.documentElement.dataset.themeDark = selectedDarkTheme;
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
    <style>
      .theme-tab-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
    </style>
    <link rel="stylesheet" href="/styles.css" />
    <script type="module" src="/main.js"></script>
  </head>
  <body>
    <div class="drawer">
      <input id="my-drawer-2" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col">
        <!-- Navbar -->
        <div class="navbar bg-base-300 w-full relative">
          <div class="flex-none lg:hidden">
            <label
              for="my-drawer-2"
              aria-label="open sidebar"
              class="btn btn-circle btn-ghost"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                class="inline-block h-6 w-6 stroke-current"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </label>
          </div>
          <div class="text-3xl font-bold mx-2 flex-1 px-2">Michael J West</div>
          <div
            class="ml-auto lg:ml-0 lg:absolute lg:left-1/2 lg:-translate-x-1/2"
          >
            <div
              class="tabs tabs-box theme-tabs rounded-full"
              role="tablist"
              aria-label="Theme selector"
            >
              <input
                id="theme-tab-system"
                type="radio"
                name="theme_tabs"
                class="theme-tab-input"
                value="system"
                checked
              />
              <label
                for="theme-tab-system"
                class="tab theme-tab-label rounded-full"
                data-theme-mode="system"
                aria-label="Use system theme"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <rect x="3" y="4" width="18" height="12" rx="2"></rect>
                  <path d="M8 20h8"></path>
                  <path d="M12 16v4"></path>
                </svg>
                <span class="sr-only">System</span>
              </label>
              <input
                id="theme-tab-light"
                type="radio"
                name="theme_tabs"
                class="theme-tab-input"
                value="light"
              />
              <label
                for="theme-tab-light"
                class="tab theme-tab-label rounded-full"
                data-theme-mode="light"
                aria-label="Use light theme"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="4"></circle>
                  <path d="M12 2v2"></path>
                  <path d="M12 20v2"></path>
                  <path d="m4.93 4.93 1.41 1.41"></path>
                  <path d="m17.66 17.66 1.41 1.41"></path>
                  <path d="M2 12h2"></path>
                  <path d="M20 12h2"></path>
                  <path d="m6.34 17.66-1.41 1.41"></path>
                  <path d="m19.07 4.93-1.41 1.41"></path>
                </svg>
                <span class="sr-only">Light</span>
              </label>
              <input
                id="theme-tab-dark"
                type="radio"
                name="theme_tabs"
                class="theme-tab-input"
                value="dark"
              />
              <label
                for="theme-tab-dark"
                class="tab theme-tab-label rounded-full"
                data-theme-mode="dark"
                aria-label="Use dark theme"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <path d="M12 3a7 7 0 1 0 9 9 9 9 0 1 1-9-9Z"></path>
                </svg>
                <span class="sr-only">Dark</span>
              </label>
            </div>
          </div>
          <div class="hidden flex-none lg:block">
            <ul class="menu menu-horizontal rounded-full">
              {
                navItems.map((item) =>
                  item.children ? (
                    <li class="mr-1">
                      <div class="dropdown dropdown-hover dropdown-end rounded-full">
                        <div
                          tabindex="0"
                          role="button"
                          class:list={[
                            "text-xl rounded-full",
                            isNavItemActive(item) &&
                              "text-primary bg-primary/15 rounded-full font-semibold",
                          ]}
                          aria-label={item.label}
                        >
                          {item.label}
                        </div>
                        <ul
                          tabindex="0"
                          class="dropdown-content menu right-0 left-auto z-[1] mt-2 w-56 rounded-box border border-base-content/15 bg-base-200 p-2 shadow-lg"
                        >
                          {item.children.map((child) => (
                            <li>
                              <a
                                href={child.href}
                                class:list={[
                                  "rounded-box",
                                  isNavItemActive(child) &&
                                    "text-primary bg-primary/15 font-semibold",
                                ]}
                                aria-current={
                                  isNavItemActive(child) ? "page" : undefined
                                }
                              >
                                {child.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </li>
                  ) : (
                    <li class="mr-1">
                      <a
                        href={item.href}
                        class:list={[
                          "text-xl rounded-full",
                          isNavItemActive(item) &&
                            "text-primary bg-primary/15 rounded-full font-semibold",
                        ]}
                        aria-current={
                          isNavItemActive(item) ? "page" : undefined
                        }
                      >
                        {item.label}
                      </a>
                    </li>
                  ),
                )
              }
            </ul>
          </div>
        </div>
        <!-- Page content -->
        <article>
          <slot />
        </article>
      </div>
      <div class="drawer-side">
        <label
          for="my-drawer-2"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <ul class="menu bg-base-300 min-h-full w-80 p-4">
          {
            navItems.map((item) =>
              item.children ? (
                <li class="mb-2">
                  <details open={isNavItemActive(item)}>
                    <summary
                      class:list={[
                        "text-xl rounded-full",
                        isNavItemActive(item) &&
                          "text-primary bg-primary/15 rounded-full font-semibold",
                      ]}
                    >
                      {item.label}
                    </summary>
                    <ul class="mt-2">
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            class:list={[
                              "rounded-box",
                              isNavItemActive(child) &&
                                "text-primary bg-primary/15 font-semibold",
                            ]}
                            aria-current={
                              isNavItemActive(child) ? "page" : undefined
                            }
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                </li>
              ) : (
                <li class="mb-2">
                  <a
                    class:list={[
                      "text-xl rounded-full",
                      isNavItemActive(item) &&
                        "text-primary bg-primary/15 rounded-full font-semibold",
                    ]}
                    href={item.href}
                    aria-current={isNavItemActive(item) ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ),
            )
          }
        </ul>
      </div>
    </div>
  </body>
</html>
