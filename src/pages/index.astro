---
import Header from "../layouts/Header.astro";
---

<Header>
  <div class="flex w-full justify-end">
    <a
      class="underline pt-4 mr-6"
      href="/Resume_MichaelJWest.pdf"
      target="_blank">View Full Resume ↗️</a
    >
  </div>
  <div class="flex w-full justify-center">
    <section
      class="max-w-4xl mx-auto px-6 py-12
               text-base-content"
    >
      <!-- Summary -->
      <div class="mb-6">
        <h2
          class="text-2xl font-semibold mb-3 border-b
               border-base-300 pb-1"
        >
          Software Engineer in Pittsburgh, PA with 8+ Years of Experience
        </h2>
        <p class="leading-relaxed text-base-content/80">
          Experienced in scaling products, owning CI/CD pipelines, mentoring
          developers, and integrating frontend systems with Restful API's
        </p>
      </div>

      <!-- Experience -->
      <div class="mb-6">
        <h2
          class="text-xl font-semibold mb-6 border-b
               border-base-300 pb-1"
        >
          💼 Experience
        </h2>

        <!-- Tactacam -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              Senior Frontend Developer – Tactacam
            </h3>
            <span class="text-sm text-base-content/60">
              2022–2026
            </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>
              Led development across multiple production mobile and web
              products.
            </li>
            <li>
              Scaled platform to 50k+ MAU; contributed to product exceeding 1M+
              MAU.
            </li>
            <li>
              Built revenue-driving features including social feeds and commerce
              flows.
            </li>
            <li>
              Integrated frontend systems with AWS serverless infrastructure.
            </li>
            <li>Owned CI/CD automation; increased release velocity.</li>
            <li>Mentored junior developers.</li>
          </ul>
        </div>

        <!-- SAE -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              Frontend Software Engineer – SAE International
            </h3>
            <span class="text-sm text-base-content/60"> 2021 </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>
              Built production Angular SPA supporting major revenue product.
            </li>
            <li>
              Contributed to shared component library used across applications.
            </li>
          </ul>
        </div>

        <!-- DDI -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              Software Engineer – DDI
            </h3>
            <span class="text-sm text-base-content/60"> 2020 </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>
              Built cross-platform data visualization and learning features.
            </li>
            <li>Worked across React Native, Angular, .NET, SQL, and D3.</li>
          </ul>
        </div>

        <!-- DevOps -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              DevOps Engineer – DDI
            </h3>
            <span class="text-sm text-base-content/60"> 2019 </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>Automated developer workflows and CI pipelines.</li>
            <li>Maintained zero-downtime deployments.</li>
          </ul>
        </div>

        <!-- Federated -->
        <div>
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              Programmer/Analyst – Federated Investors
            </h3>
            <span class="text-sm text-base-content/60">
              2017–2018
            </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>Maintained large-scale SQL and PowerShell systems.</li>
            <li>Delivered rapid prototype securing executive approval.</li>
          </ul>
        </div>
      </div>

      <!-- Skills -->
      <div class="mb-6">
        <h2
          class="text-xl font-semibold mb-4 border-b
               border-base-300 pb-1"
        >
          🛠️ Skills & Tooling
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
          <div>
            <p class="font-medium text-base-content mb-1">
              Languages
            </p>
            <p class="text-base-content/80">
              JavaScript, TypeScript, SQL, Java
            </p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">
              Frontend Frameworks
            </p>
            <p class="text-base-content/80">
              React, React Native, Angular, Next.js, Tailwind
            </p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">Cloud</p>
            <p class="text-base-content/80">
              AWS (CDK, Lambda, API Gateway, DynamoDB, S3)
            </p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">
              DevOps & Testing
            </p>
            <p class="text-base-content/80">
              GitHub Actions, EAS, Jest, Appium, WebDriverIO
            </p>
          </div>
        </div>
      </div>

      <!-- Education -->
      <div>
        <h2
          class="text-xl font-semibold mb-4 border-b
               border-base-300 pb-1"
        >
          👨🏼‍🎓 Education
        </h2>
        <p class="font-semibold text-base-content">
          B.S. Computer Engineering – University of Pittsburgh
        </p>
        <p class="text-sm text-base-content/70 mt-1">
          Focus areas: software engineering, systems design, software testing,
          and computer architecture.
        </p>
      </div>
    </section>
  </div>
</Header>
