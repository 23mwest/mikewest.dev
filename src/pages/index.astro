---
import Header from "../layouts/Header.astro";
---

<Header>
  <div class="flex w-full justify-center">
    <section
      class="max-w-4xl mx-auto px-6 py-12
               text-base-content"
    >
      <!-- Summary -->
      <div class="mb-6">
        <h2 class="text-2xl font-semibold mb-3 border-b
                pb-1">
          Senior Frontend Software Engineer in Pittsburgh, PA
        </h2>
        <p class="leading-relaxed text-base-content/80">
          8+ years building web and mobile products from early-stage MVPs to
          platforms with tens of thousands of active users. Specializing in
          React, React Native, and Next.js, with full-stack support across
          frontend architecture, state management, serverless infrastructure,
          and CI/CD automation.
        </p>
      </div>

      <!-- Experience -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-6 border-b
                pb-1">
          <span class="inline-flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <rect x="3" y="7" width="18" height="13" rx="2"></rect>
              <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              <path d="M3 13h18"></path>
            </svg>
            Recent Work
          </span>
        </h2>

        <!-- Tactacam -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">Tactacam</h3>
            <span class="text-sm text-base-content/60"> 2022–2026 </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>
              Grew from engineer to lead developer on a React Native + Next.js
              platform.
            </li>
            <li>
              Scaled from zero to 50,000 monthly active users in under two
              years.
            </li>
            <li>Led a team of 5 and shipped monetization features.</li>
            <li>
              Owned CI/CD infrastructure, increasing release frequency by
              roughly 3x.
            </li>
          </ul>
        </div>

        <!-- SAE -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              SAE International
            </h3>
            <span class="text-sm text-base-content/60"> 2021 </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>
              Built complex onboarding flows in Angular for a core revenue
              product.
            </li>
            <li>
              Contributed shared UI components consumed across 10+ internal
              applications.
            </li>
          </ul>
        </div>

        <!-- DDI + Federated -->
        <div class="mb-8">
          <div class="flex justify-between flex-wrap">
            <h3 class="font-semibold text-lg text-base-content">
              DDI & Federated Investors
            </h3>
            <span class="text-sm text-base-content/60"> 2017–2020 </span>
          </div>
          <ul
            class="list-disc list-inside mt-3 space-y-2
                 text-base-content/80"
          >
            <li>
              Roles spanning data visualization, mobile development, DevOps
              automation, and rapid prototyping.
            </li>
            <li>
              Worked across frontend and backend systems with production
              delivery ownership.
            </li>
          </ul>
        </div>
      </div>

      <!-- Skills -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-4 border-b
                pb-1">
          <span class="inline-flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.2 2.2-2.6-.6-.6-2.6 2.4-2.6Z"
              ></path>
            </svg>
            Skills & Tools
          </span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
          <div>
            <p class="font-medium text-base-content mb-1">Languages</p>
            <p class="text-base-content/80">JavaScript, TypeScript, SQL</p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">Frontend</p>
            <p class="text-base-content/80">
              React, React Native, Next.js, Angular, Expo, Tailwind, TanStack,
              GraphQL
            </p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">Cloud</p>
            <p class="text-base-content/80">
              AWS (CDK, Lambda, API Gateway, S3, SNS)
            </p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">DevOps</p>
            <p class="text-base-content/80">
              GitHub Actions, Expo EAS, CodeMagic, AWS Amplify, Azure DevOps
            </p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">Testing</p>
            <p class="text-base-content/80">Jest, React Testing Library</p>
          </div>
          <div>
            <p class="font-medium text-base-content mb-1">Analytics</p>
            <p class="text-base-content/80">Google Analytics, Survicate</p>
          </div>
        </div>
      </div>

      <!-- Education -->
      <div>
        <h2 class="text-xl font-semibold mb-4 border-b
                pb-1">
          <span class="inline-flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="m2 8 10-5 10 5-10 5L2 8Z"></path>
              <path d="M6 10.5V15a6 6 0 0 0 12 0v-4.5"></path>
            </svg>
            Education
          </span>
        </h2>
        <p class="font-semibold text-base-content">
          B.S. Computer Engineering – University of Pittsburgh
        </p>
        <p class="text-sm text-base-content/70 mt-1">
          Minor: Industrial Engineering
        </p>
      </div>
    </section>
  </div>
</Header>
