---
import Header from "../layouts/Header.astro";
---

<Header>
  <section class="max-w-3xl mx-auto px-6 py-12 text-base-content">
    <h1 class="text-3xl font-bold mb-3">Links</h1>
    <p class="text-base-content/80 mb-8">
      Quick links to my profiles and projects.
    </p>

    <div
      class="rounded-box bg-base-100 border-2 border-solid border-base-content/60 p-6"
    >
      <ul class="space-y-4">
        <li>
          <a
            class="link link-hover text-xl inline-flex items-center gap-2"
            href="mailto:23mwest@gmail.com"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
            Email
          </a>
        </li>
        <li>
          <a
            class="link link-hover text-xl inline-flex items-center gap-2"
            href="https://github.com/23mwest"
            target="_blank"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path
                d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.02c-3.34.73-4.04-1.61-4.04-1.61a3.17 3.17 0 0 0-1.33-1.75c-1.09-.74.08-.73.08-.73a2.5 2.5 0 0 1 1.82 1.23 2.54 2.54 0 0 0 3.47.99 2.54 2.54 0 0 1 .76-1.59c-2.67-.3-5.47-1.34-5.47-5.95a4.66 4.66 0 0 1 1.24-3.23 4.33 4.33 0 0 1 .12-3.19s1.01-.32 3.3 1.23a11.4 11.4 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23a4.33 4.33 0 0 1 .12 3.19 4.66 4.66 0 0 1 1.24 3.23c0 4.62-2.81 5.64-5.49 5.94a2.84 2.84 0 0 1 .81 2.2v3.25c0 .32.22.69.82.58A12 12 0 0 0 12 .5Z"
              ></path>
            </svg>
            GitHub
          </a>
        </li>
        <li>
          <a
            class="link link-hover text-xl inline-flex items-center gap-2"
            href="https://www.linkedin.com/in/michaeljosephwest"
            target="_blank"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path
                d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.03-1.85-3.03-1.85 0-2.13 1.44-2.13 2.93v5.68H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.23 0H1.77A1.77 1.77 0 0 0 0 1.77v20.46C0 23.2.8 24 1.77 24h20.46c.98 0 1.77-.8 1.77-1.77V1.77C24 .8 23.2 0 22.23 0Z"
              ></path>
            </svg>
            LinkedIn
          </a>
        </li>
      </ul>
    </div>
  </section>
</Header>
